# syntax=docker/dockerfile:1

############################
# 1) дҫқиө– + жһ„е»әйҳ¶ж®ө
############################
FROM node:20.20.2-bookworm-slim AS builder

# better-sqlite3 жҳҜеҺҹз”ҹжЁЎеқ—пјҢиӢҘйў„зј–иҜ‘дәҢиҝӣеҲ¶зјәеӨұйңҖиҰҒиҝҷдәӣе·Ҙе…·зҺ°еңәзј–иҜ?
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

# еӣәе®ҡ pnpm еҲ?v10пјҲpnpm 11 дёҚеҶҚиҜ»еҸ– package.json зҡ?"pnpm.onlyBuiltDependencies"пј?
# дјҡи·іиҝ?better-sqlite3 зҡ„еҺҹз”ҹзј–иҜ‘е№¶жҠ?ERR_PNPM_IGNORED_BUILDSпјӣv10 е…је®№ lockfile 9.0пјүгҖ?
# з”ЁеӣҪеҶ…й•ңеғҸйҖҡиҝҮ npm е®үиЈ…пјҢйҒҝе…?corepack жӢүеҸ– tarball и¶…ж—¶гҖ?
RUN npm install -g pnpm@10.34.4 --registry=https://registry.npmmirror.com

WORKDIR /app

# е…ҲеӨҚеҲ¶дҫқиө–жё…еҚ•пјҢеҲ©з”Ё Docker еұӮзј“еӯ?
COPY package.json pnpm-lock.yaml .npmrc ./

# е®үиЈ…е…ЁйғЁдҫқиө–пјҲеҗ« devDependenciesпјҢжһ„е»әйңҖиҰ?nest cli / tsпј?
RUN pnpm install --frozen-lockfile

# еӨҚеҲ¶жәҗз Ғе№¶жһ„е»?
COPY . .
RUN pnpm run build

# еҸӘдҝқз•ҷз”ҹдә§дҫқиө–пјҢзј©е°ҸдҪ“з§Ҝ
RUN pnpm prune --prod

############################
# 2) иҝҗиЎҢйҳ¶ж®ө
############################
FROM node:20.20.2-bookworm-slim AS runner

ENV NODE_ENV=production \
    PORT=3000 \
    DATABASE_PATH=/app/data/auto-ve.db

WORKDIR /app

# жӢ·иҙқжһ„е»әдә§зү©дёҺз”ҹдә§дҫқиө?
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/package.json ./package.json

# ж•°жҚ®еә?/ иҝҗиЎҢжңҹж•°жҚ®зӣ®еҪ•пјҲе»әи®®иҝҗиЎҢж—¶з”Ё -v жҢӮиҪҪжҢҒд№…еҢ–пјү
RUN mkdir -p /app/data

EXPOSE 3000

CMD ["node", "dist/main"]
